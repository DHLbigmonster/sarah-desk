# ─── 语音识别（火山引擎豆包 ASR）───────────────────────────────────────────────
# 用于 Mode 1（光标插字）和 Mode 2（Agent 语音指令）的服务端 ASR。
# 复制此文件为 .env 并填入真实值。

# APP ID（从火山引擎控制台 → 应用管理 获取）
VOLCENGINE_APP_ID=4120356295

# Access Token（从「流式语音识别大模型」页面 → 点击眼睛图标 查看）
VOLCENGINE_ACCESS_TOKEN=your_access_token_here

# Resource ID（默认大模型 1.0 流式识别）
VOLCENGINE_RESOURCE_ID=volc.bigasr.sauc.duration

# 可选：开启二遍识别，提高最终结果质量
VOLCENGINE_ENABLE_NONSTREAM=true

# 可选：火山豆包语音热词词表（二选一）
# VOLCENGINE_BOOSTING_TABLE_ID=your_hotword_table_id
# VOLCENGINE_BOOSTING_TABLE_NAME=your_hotword_table_name

# 可选：火山豆包语音替换词词表（二选一）
# VOLCENGINE_CORRECT_TABLE_ID=your_correct_table_id
# VOLCENGINE_CORRECT_TABLE_NAME=your_correct_table_name

# ─── Dictation refinement（火山方舟轻量文本模型）──────────────────────────────
# Dictation 正常路径会先调用轻量文本模型，再插入输入框。

# 方舟 API Key
# ARK_API_KEY=your_ark_api_key

# 建议优先配置自建 Endpoint ID；如无自建 Endpoint，可临时配置公共模型名。
# DICTATION_REFINEMENT_ENDPOINT_ID=ep-xxxxxxxxxxxxxxxx
# DICTATION_REFINEMENT_MODEL=doubao-lite-32k

# 可选：默认即方舟 OpenAI 兼容入口
# DICTATION_REFINEMENT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选：超时和输出长度
# DICTATION_REFINEMENT_TIMEOUT_MS=4500
# DICTATION_REFINEMENT_MAX_TOKENS=220
# DICTATION_REFINEMENT_TEMPERATURE=0.2

# ─── 热键配置 ─────────────────────────────────────────────────────────────────
#
# 三种触发模式：
#
#   Mode 1  Hold Right Option  →  语音 → 光标插字（push-to-talk，不改这里也能用）
#   Mode 2  Hold Right Ctrl    →  语音 → AI Agent 执行（需要以下 AGENT_VOICE_KEY）
#   Mode 3  Cmd+Shift+Space    →  截图上下文 → Agent 面板（改 AGENT_HOTKEY）
#
# AGENT_VOICE_KEY: uiohook-napi UiohookKey 的成员名称，默认 CtrlRight
# 可用值: CtrlRight, CtrlLeft, AltRight, AltLeft, MetaRight, MetaLeft …
AGENT_VOICE_KEY=CtrlRight

# AGENT_HOTKEY: Electron globalShortcut 格式，默认 CommandOrControl+Shift+Space
AGENT_HOTKEY=CommandOrControl+Shift+Space
